# Flask
SECRET_KEY=your-long-random-secret-key
FLASK_ENV=production

# Database (MySQL)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password
MYSQL_DATABASE=freelance_marketplace
DATABASE_URL=mysql+pymysql://user:password@host:3306/dbname

# Mail (Gmail SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=adminfreelancemarketplace.dev@gmail.com
MAIL_DEFAULT_SENDER=FreelancingHub <adminfreelancemarketplace.dev@gmail.com>
MAIL_PASSWORD=your-gmail-app-password

# M-Pesa Daraja API
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://yourdomain.com/mpesa/callback
MPESA_B2C_SHORTCODE=
MPESA_INITIATOR_NAME=
MPESA_SECURITY_CREDENTIAL=

# Redis (Celery + Rate limiting)
REDIS_URL=redis://localhost:6379/0

# Admin default account
ADMIN_EMAIL=admin@example.com
ADMIN_PWD=changeme

# Feature flags
USE_MOCK_VISION=False
TESSERACT_CMD=
